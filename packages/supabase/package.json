{
  "name": "@heroitvn/supabase",
  "version": "0.1.0",
  "private": true,
  "description": "Supabase browser, server, and proxy clients for Next.js",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./proxy": {
      "types": "./src/proxy.ts",
      "import": "./src/proxy.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
