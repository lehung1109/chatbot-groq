{
  "name": "@heroitvn/chatbot-toggle",
  "version": "0.1.0",
  "description": "Workspace package for ChatbotToggle and chatbot module exports",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
